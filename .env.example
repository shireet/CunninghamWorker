# Application Settings
APP_ENV=development
LOG_LEVEL=INFO

# Telegram Configuration (User Account)
TELEGRAM_API_ID=your-api-id-here
TELEGRAM_API_HASH=your-api-hash-here
TELEGRAM_PHONE=+1234567890
TELEGRAM_SESSION_STRING=

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE_NAME=execution_jobs

# Core API Configuration
CORE_API_BASE_URL=http://localhost:8080
CORE_API_TIMEOUT_SECONDS=120

# Worker Configuration
WORKER_POLL_TIMEOUT_SECONDS=10
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5
